# Application Configuration
VITE_APP_NAME="KYCtrust للخدمات الرقمية"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENVIRONMENT="development"

# Supabase Configuration
VITE_SUPABASE_URL="your_supabase_url_here"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SECRET_KEY="your_supabase_secret_key_here"

# Admin Panel Configuration
VITE_ADMIN_EMAIL="admin@kyctrust.com"
VITE_ADMIN_PASSWORD="admin123"

# WhatsApp Integration
VITE_WHATSAPP_NUMBER="+966501234567"
VITE_WHATSAPP_API_URL=""

# Email Configuration (Optional)
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""
EMAIL_FROM_ADDRESS="noreply@kyctrust.com"
EMAIL_FROM_NAME="KYCtrust"

# SMS Configuration (Optional)
SMS_PROVIDER="none"
SMS_API_KEY=""
SMS_SENDER_ID="KYCtrust"

# Payment Integration (Optional)
PAYMENT_PROVIDER="none"
MADA_API_KEY=""
STC_PAY_API_KEY=""
PAYPAL_CLIENT_ID=""
STRIPE_PUBLIC_KEY=""

# Security Configuration
JWT_SECRET="your_jwt_secret_here"
SESSION_SECRET="your_session_secret_here"
BCRYPT_ROUNDS="12"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# File Upload Configuration
MAX_FILE_SIZE="10485760"
ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx"
UPLOAD_PATH="./uploads"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
FACEBOOK_PIXEL_ID=""

# Error Monitoring (Optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Database Backup
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
BACKUP_S3_BUCKET=""
BACKUP_S3_ACCESS_KEY=""
BACKUP_S3_SECRET_KEY=""

# API Configuration
API_BASE_URL="http://localhost:3000/api"
API_TIMEOUT="30000"
API_RATE_LIMIT="100"

# SSL/TLS Configuration
SSL_ENABLED="false"
SSL_CERT_PATH=""
SSL_KEY_PATH=""

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Logging
LOG_LEVEL="info"
LOG_FILE_PATH="./logs/app.log"
LOG_MAX_SIZE="10m"
LOG_MAX_FILES="5"

# Cache Configuration
REDIS_URL=""
CACHE_TTL="3600"

# Development Tools
DEBUG="true"
VITE_DEV_TOOLS="true"
HOT_RELOAD="true"

# Production Optimization
ENABLE_COMPRESSION="true"
ENABLE_MINIFICATION="true"
ENABLE_TREE_SHAKING="true"

# Custom Features
ENABLE_MULTILANGUAGE="true"
ENABLE_DARK_MODE="true"
ENABLE_PWA="true"
ENABLE_OFFLINE_MODE="false"

# Third Party Integrations
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
MAPS_API_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Maintenance Mode
MAINTENANCE_MODE="false"
MAINTENANCE_MESSAGE="الموقع تحت الصيانة. سنعود قريباً!"
MAINTENANCE_ALLOWED_IPS="127.0.0.1,::1"

# Social Media Integration
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
FACEBOOK_APP_ID=""
LINKEDIN_API_KEY=""
